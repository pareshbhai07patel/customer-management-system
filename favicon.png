:root {
    --primary: #6366f1;
    --accent: #10b981;
    --dark-bg: #030712;
    --card-bg: rgba(17, 24, 39, 0.7); /* Darker, cleaner glass */
    --border: rgba(255, 255, 255, 0.08);
    --text-main: #f9fafb;
    --text-dim: #9ca3af;
}

* { box-sizing: border-box; }

body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background-color: var(--dark-bg);
    color: var(--text-main);
    overflow: hidden; /* No scrollbars on the body */
}

/* --- LAYOUT --- */
.app-container {
    display: flex;
    height: 100vh;
    width: 100vw;
}

/* Sidebar Styling */
.sidebar {
    width: 260px;
    background: #0f172a; /* Slightly lighter than body */
    border-right: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between; /* Pushes logout to bottom */
}

/* Main Content Styling */
.main-content {
    flex: 1;
    padding: 2.5rem;
    overflow-y: auto; /* Scroll inside main area only */
    background: radial-gradient(circle at top right, #1e1b4b 0%, var(--dark-bg) 60%);
}

/* --- CARDS & GLASSMORPHISM --- */
.glass-card {
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
}

/* --- INPUTS & BUTTONS --- */
input, select {
    background: rgba(0, 0, 0, 0.3) !important;
    border: 1px solid var(--border) !important;
    color: white !important;
    border-radius: 8px;
    padding: 10px 14px;
    outline: none;
    font-family: inherit;
    transition: 0.2s;
}
input:focus, select:focus {
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

.btn-primary {
    background: var(--primary);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary:hover {
    background: #4f46e5;
    transform: translateY(-1px);
}

/* --- TABLE FIXES (The Important Part) --- */
table {
    width: 100%;
    border-collapse: separate; /* Allows spacing adjustments */
    border-spacing: 0;
}

thead {
    background: rgba(255, 255, 255, 0.03);
}

th {
    text-align: left;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 16px 24px; /* Bigger padding for alignment */
    border-bottom: 1px solid var(--border);
    font-weight: 600;
}

td {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle; /* Centers text vertically with dropdowns */
    font-size: 0.95rem;
}

/* Align the last column (Actions) to the right */
th:last-child, td:last-child {
    text-align: right;
}

/* Row Hover Effect */
tbody tr:hover {
    background: rgba(255, 255, 255, 0.02);
}

/* --- UTILS --- */
.hidden { display: none !important; }
#top-progress-bar {
    position: fixed; top: 0; left: 0; height: 3px; width: 0%;
    background: var(--primary); z-index: 9999; transition: width 0.3s;
}

/* --- TOAST NOTIFICATIONS --- */
#toast-container {
    position: fixed;
    bottom: 30px;
    right: 30px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 10000;
}

.toast {
    min-width: 250px;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(10px);
    color: white;
    padding: 16px 20px;
    border-radius: 12px;
    border-left: 4px solid var(--primary);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    transform: translateX(120%);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.toast.show { transform: translateX(0); }
.toast.success { border-left-color: #10b981; }
.toast.error { border-left-color: #ef4444; }

/* --- KANBAN BOARD STYLES --- */
.kanban-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4 Columns */
    gap: 15px;
    margin-top: 20px;
    animation: floatUp 0.5s ease;
}

.kanban-col {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 15px;
    min-height: 400px;
}

.kanban-header {
    font-size: 0.8rem;
    font-weight: 800;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.kanban-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
    transition: all 0.2s;
    position: relative;
}

.kanban-card:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    border-color: rgba(255,255,255,0.1);
}


/* --- DRAG & DROP STYLES --- */
.kanban-card {
    cursor: grab; /* Shows a hand cursor */
}

.kanban-card:active {
    cursor: grabbing;
    transform: scale(0.98);
}

/* When dragging over a column, highlight it */
.kanban-col.drag-over {
    background: rgba(99, 102, 241, 0.2); /* Light Blue Highlight */
    border: 1px dashed #6366f1;
    transition: 0.2s;
}

/* --- HERO VISUALS (The "Image Alternative") --- */
.hero-visual-container {
    position: relative;
    perspective: 1000px; /* Creates 3D depth */
}

.glass-mockup {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 2rem;
    transform: rotateY(-10deg) rotateX(5deg); /* Tilted 3D Look */
    box-shadow: 
        20px 20px 50px rgba(0,0,0,0.5),
        -1px -1px 0px rgba(255,255,255,0.2) inset;
    transition: transform 0.5s ease;
    animation: float 6s ease-in-out infinite;
}

.glass-mockup:hover {
    transform: rotateY(0deg) rotateX(0deg) scale(1.02);
}

/* Floating Animation */
@keyframes float {
    0% { transform: rotateY(-10deg) rotateX(5deg) translateY(0px); }
    50% { transform: rotateY(-10deg) rotateX(5deg) translateY(-20px); }
    100% { transform: rotateY(-10deg) rotateX(5deg) translateY(0px); }
}

/* --- VIDEO MODAL --- */
.video-modal-overlay {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(10px);
}

.video-modal-overlay.active {
    opacity: 1;
    pointer-events: all;
}

.video-wrapper {
    width: 80%;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    background: black;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 50px rgba(99, 102, 241, 0.3);
    border: 1px solid rgba(255,255,255,0.1);
}

/* --- HERO IMAGE STYLES --- */
.hero-image-wrapper {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); /* Deep shadow */
    border: 1px solid rgba(255, 255, 255, 0.1); /* Glass border */
    /* Floating Animation */
    animation: floatImage 6s ease-in-out infinite;
}

/* Ensure the image fills the container */
.hero-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    /* Optional: Dim the image slightly to match dark theme */
    filter: brightness(0.9) contrast(1.1); 
}

@keyframes floatImage {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
}

